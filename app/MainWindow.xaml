<Window x:Class="SidetoneApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sidetone"
        Width="380"
        Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E90FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#202020" CornerRadius="8" Padding="0">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock Text="Sidetone"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinimizeBtn"
                                Width="46" Height="32"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeBtn"
                                Width="46" Height="32"
                                Background="Transparent"
                                Foreground="#808080"
                                BorderThickness="0"
                                IsEnabled="False"/>
                        <Button x:Name="CloseBtn"
                                Width="46" Height="32"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="20">
                <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Enable sidetone to hear your microphone"
                   FontSize="14"
                   TextAlignment="Center"
                   Margin="0,0,0,16"/>

        <Button Grid.Row="1"
                x:Name="ToggleButton"
                Content="Stop"
                Click="ToggleButton_Click"
                Width="300"
                Height="40"
                Margin="0,0,0,24"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Playback Volume" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="GainValue" Text="25%" FontSize="13" HorizontalAlignment="Right"/>
            </Grid>
            <Slider x:Name="GainSlider"
                    Minimum="0" Maximum="200"
                    Value="25"
                    ValueChanged="GainSlider_ValueChanged"
                    Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Noise Suppression" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="SuppressValue" Text="75%" FontSize="13" HorizontalAlignment="Right"/>
            </Grid>
            <Slider x:Name="SuppressSlider"
                    Minimum="0" Maximum="100"
                    Value="75"
                    ValueChanged="SuppressSlider_ValueChanged"
                    Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Microphone Gain" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="InputGainValue" Text="100%" FontSize="13" HorizontalAlignment="Right"/>
            </Grid>
            <Slider x:Name="InputGainSlider"
                    Minimum="0" Maximum="200"
                    Value="100"
                    ValueChanged="InputGainSlider_ValueChanged"
                    Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="Sidetone"
                   FontSize="11"
                   Foreground="#606060"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
